+func TestLogin_Valid(t *testing.T) {
+	d, cfg, _ := setupTestEnv(t)
+	defer d.Close()
+	mustCreateUser(t, d, "admin", "admin123", false)
+
+	h := NewAuthHandler(d, cfg)
